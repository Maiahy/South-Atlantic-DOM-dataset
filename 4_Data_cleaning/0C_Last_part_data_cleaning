compute_rsd <- function(df) {
  
  median_vals <- df %>%
    summarise(across(starts_with("FT"), median, na.rm = TRUE))
  
  mad_vals <- df %>%
    summarise(across(starts_with("FT"), mad, na.rm = TRUE))
  
  rsd <- (1.4826 * mad_vals) /
    ifelse(median_vals == 0, NA, median_vals) * 100
  
  return(as.numeric(rsd))
}


RSD_list_after <- DM_QC_after %>%
  group_split(ESSENTIAL_sample_id)

names(RSD_list_after) <- unique(DM_QC_after$ESSENTIAL_sample_id)

RSD_results_after <- lapply(RSD_list_after, compute_rsd)

RSD_df_after <- do.call(cbind, RSD_results_after)
colnames(RSD_df_after) <- names(RSD_results_after)
RSD_df_after <- as.data.frame(RSD_df_after)

RSD_summary_after <- do.call(rbind, lapply(names(RSD_df_after), function(batch) {
  
  tab <- table(cut(RSD_df_after[[batch]],
                   breaks = c(-Inf, 20, 30, 50, Inf),
                   labels = c("0-20%", "20-30%", "30-50%", ">50%")))
  
  data.frame(
    batch = batch,
    RSD_bin = names(tab),
    n = as.numeric(tab)
  )
}))

