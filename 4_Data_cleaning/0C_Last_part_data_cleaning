#In this part, we will investigate the quality of the SERRF 
#normalization through diverse plots.
#First, we will check if when we plot the intensities of a given feature
#within our pooled QC, this intensity appears more stable after SERRF than 
#before, and if no artefact was generated.

library(ggplot2)
library(dplyr)
library(tidyr)

#Keep only the pooled QC samples in the metadata
qc_meta <- metadata_samples %>%
  filter(ESSENTIAL_sample_type == "REF") %>%
  select(file_name, Injection_order, batch_identifier)

#Keep only the QC in the table generated before SERFF
qc_dm3 <- DM_i4 %>%
  filter(file_name %in% qc_meta$file_name) %>%
