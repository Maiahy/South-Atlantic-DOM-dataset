#####3) RSD filtering####

#Define the threshold you want to apply to the RSD of the dataset
threshold <- 20  

#Function to calculate the RSD
calc_rsd <- function(x) {
  x <- as.numeric(x)
  if (mean(x, na.rm = TRUE) == 0) return(NA)
  100 * sd(x, na.rm = TRUE) / mean(x, na.rm = TRUE)
}

#Fonction to calculate the RSD by group!
compute_rsd_summary <- function(data_matrix, metadata, group_var) {
  metadata_sub <- metadata %>%
    filter(ESSENTIAL_sample_type %in% c("QC", "REF")) %>%
    select(file_name, ESSENTIAL_sample_type, ESSENTIAL_sample_id) %>%
    mutate(group_id = ifelse(ESSENTIAL_sample_type == "REF", "REF", as.character(ESSENTIAL_sample_id)))
  
#Join data to metadata
  data_joined <- inner_join(data_matrix, metadata_sub, by = "file_name")
  #Create RSD Summary
  rsd_summary <- data_joined %>%
    group_by(group_id) %>%
    summarise(across(all_of(ft_cols), calc_rsd)) %>%
    pivot_longer(-group_id, names_to = "feature", values_to = "RSD") %>%
    group_by(group_id) %>%
    summarise(
      average_RSD = mean(RSD, na.rm = TRUE),
      n_below_20 = sum(RSD < threshold, na.rm = TRUE)
    )
  
  return(rsd_summary)
}

#Apply the function to the raw data
rsd_raw <- compute_rsd_summary(DM_i4, metadata_samples, "ESSENTIAL_sample_id") %>%
  mutate(state = "Before")

#Apply the function to the normalized data
rsd_norm <- compute_rsd_summary(DM_i5, metadata_samples, "ESSENTIAL_sample_id") %>%
  mutate(state = "After")

#Fusion the results and print!
rsd_compare <- bind_rows(rsd_raw, rsd_norm) %>%
  arrange(group_id, state)

print(rsd_compare)


